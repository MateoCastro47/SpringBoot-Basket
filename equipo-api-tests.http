### Variables
@baseUrl = http://localhost:8080
@equipoId = 1

###############################################
# EQUIPO API TESTS
###############################################

### 1. Listar todos los equipos (inicialmente vacío)
GET {{baseUrl}}/api/equipos

### 2. Crear equipo - Real Madrid
POST {{baseUrl}}/api/equipos
Content-Type: application/json

{
  "nombre": "Real Madrid",
  "fechaFundacion": "1902-03-06",
  "ciudad": "Madrid",
  "presupuesto": 800000000
}

### 3. Crear equipo - FC Barcelona
POST {{baseUrl}}/api/equipos
Content-Type: application/json

{
  "nombre": "FC Barcelona",
  "fechaFundacion": "1899-11-29",
  "ciudad": "Barcelona",
  "presupuesto": 750000000
}

### 4. Crear equipo - Atlético Madrid
POST {{baseUrl}}/api/equipos
Content-Type: application/json

{
  "nombre": "Atlético Madrid",
  "fechaFundacion": "1903-04-26",
  "ciudad": "Madrid",
  "presupuesto": 400000000
}

### 5. Listar todos los equipos (después de crear)
GET {{baseUrl}}/api/equipos

### 6. Obtener equipo por ID (ID = 1)
GET {{baseUrl}}/api/equipos/{{equipoId}}

### 7. Actualizar equipo (aumentar presupuesto)
PUT {{baseUrl}}/api/equipos/{{equipoId}}
Content-Type: application/json

{
  "nombre": "Real Madrid CF",
  "fechaFundacion": "1902-03-06",
  "ciudad": "Madrid",
  "presupuesto": 850000000
}

### 8. Obtener equipo actualizado
GET {{baseUrl}}/api/equipos/{{equipoId}}

### 9. Intentar obtener equipo inexistente (debería dar 404)
GET {{baseUrl}}/api/equipos/999

### 10. Eliminar equipo
DELETE {{baseUrl}}/api/equipos/{{equipoId}}

### 11. Verificar que fue eliminado (debería dar 404)
GET {{baseUrl}}/api/equipos/{{equipoId}}
